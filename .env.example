# Application
APP_NAME=developer-landing-api
APP_ENV=development
APP_VERSION=0.1.0
STORAGE_DIR=storage
LOG_FILE=storage/logs/app.log
FRONTEND_DIST_DIR=frontend/dist/frontend/browser

# CORS
# Comma-separated list. Use your deployed frontend/domain in production.
CORS_ORIGINS=http://localhost:4200,http://localhost:8000

# AI provider: OpenAI-compatible chat completions API
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-5.4-nano
AI_TIMEOUT_SECONDS=10

# Contact/email
CONTACT_OWNER_EMAIL=owner@example.com
EMAIL_FROM=no-reply@example.com
EMAIL_PROVIDER=smtp
RESEND_API_KEY=
RESEND_BASE_URL=https://api.resend.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# Rate limiting
RATE_LIMIT_IP_REQUESTS=5
RATE_LIMIT_IP_WINDOW_SECONDS=600
RATE_LIMIT_EMAIL_REQUESTS=3
RATE_LIMIT_EMAIL_WINDOW_SECONDS=3600

# Metrics endpoint
# If set, GET /api/metrics requires header: X-API-Key: <value>
METRICS_API_KEY=
